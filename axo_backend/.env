# Server Configuration
PORT=5000
NODE_ENV=production

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=axo_networks
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Configuration
JWT_SECRET=axo_networks_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=/home/ec2-user/axo/uploads

# CORS
CORS_ORIGIN=https://axonetworks.com

# Email (for future)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
